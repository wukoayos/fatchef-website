# Google Maps Embed API key (used in src/components/Locations.tsx)
# Restrict this key to Maps Embed API + your domains in GCP console.
REACT_APP_GOOGLE_MAPS_API_KEY=

# Google Places API key (used by scripts/fetch-reviews.js, CI only)
# Not needed for local dev. Used in GitHub Actions `update-reviews` workflow.
GOOGLE_PLACES_API_KEY=
